NODE_ENV=development
PORT=5000
API_VERSION=v1

# Database — use one of:
#   Docker:  postgresql://erp_user:erp_password@localhost:5432/academic_erp?schema=public
#   Local:   postgresql://YOUR_USER:YOUR_PASSWORD@localhost:5432/academic_erp?schema=public
#   Supabase: paste your project's connection string from Dashboard → Settings → Database
DATABASE_URL=postgresql://erp_user:erp_password@localhost:5432/academic_erp?schema=public

# JWT (RS256 — generate with openssl)
JWT_ACCESS_SECRET=your-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Redis (set REDIS_ENABLED=true when Redis is running)
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379

# CORS
FRONTEND_URL=http://localhost:5173

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (SendGrid / SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@yourdomain.com

# Super Admin seed
SUPER_ADMIN_EMAIL=admin@erp.local
SUPER_ADMIN_PASSWORD=ChangeMe@123
