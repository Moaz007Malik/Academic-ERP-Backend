generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum InstituteStatus {
  ACTIVE
  SUSPENDED
  BLOCKED
  EXPIRED
}

enum UserRole {
  SUPER_ADMIN
  INSTITUTE_ADMIN
  TEACHER
  STUDENT
  PARENT
  ACCOUNTANT
  HR
  LIBRARIAN
  RECEPTIONIST
  STAFF
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  YEARLY
  CUSTOM
}

enum InvoiceType {
  INITIAL
  RENEWAL
  EXTENSION
}

enum InvoiceStatus {
  PENDING
  PAID
  CANCELLED
}

enum StudentStatus {
  ACTIVE
  ALUMNI
  EXPELLED
  TRANSFERRED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum TeacherStatus {
  ACTIVE
  INACTIVE
  RESIGNED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LEAVE
  LATE
}

enum FeeStatus {
  PENDING
  PAID
  PARTIAL
  WAIVED
}

enum TicketCategory {
  PASSWORD_RESET
  LOGO_UPDATE
  STORAGE
  FEATURE_REQUEST
  CARD_DESIGN
  SUBSCRIPTION
  OTHER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ExamType {
  MONTHLY
  MID_TERM
  FINAL
  BOARD
  SUPPLY
}

// ─── Platform Tables (no instituteId) ────────────────────────────────────────

model SubscriptionPlan {
  id             String       @id @default(uuid())
  name           String       @db.VarChar(100)
  billingCycle   BillingCycle
  price          Decimal      @db.Decimal(10, 2)
  storageQuotaMB Int          @default(5120)
  maxUsers       Int          @default(500)
  allowedModules String[]
  isCustom       Boolean      @default(false)
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())

  institutes Institute[]
  invoices   SubscriptionInvoice[]
}

// ─── Tenant Root ─────────────────────────────────────────────────────────────

model Institute {
  id              String          @id @default(uuid())
  instituteCode   String          @unique @db.VarChar(20)
  name            String          @db.VarChar(200)
  logo            String?         @db.VarChar(500)
  address         String?
  phone           String?         @db.VarChar(20)
  email           String?         @db.VarChar(200)
  status          InstituteStatus @default(ACTIVE)
  planId          String?
  plan            SubscriptionPlan? @relation(fields: [planId], references: [id])
  storageQuotaMB  Int             @default(5120)
  storageUsedMB   Int             @default(0)
  activeModules   String[]
  expiryDate      DateTime?
  deletedAt       DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  users              User[]
  students           Student[]
  teachers           Teacher[]
  departments        Department[]
  courses            Course[]
  subjects           Subject[]
  batches            Batch[]
  sections           Section[]
  sessions           Session[]
  semesters          Semester[]
  attendance         Attendance[]
  feeStructures      FeeStructure[]
  fees               Fee[]
  exams              Exam[]
  results            Result[]
  timetable          Timetable[]
  assignments        Assignment[]
  libraryBooks       LibraryBook[]
  libraryIssues      LibraryIssue[]
  hostelRooms        HostelRoom[]
  hostelAllotments   HostelAllotment[]
  transportRoutes    TransportRoute[]
  transportAllotments TransportAllotment[]
  notifications      Notification[]
  announcements      Announcement[]
  cardDesigns        CardDesign[]
  certificates       Certificate[]
  loginHistory       LoginHistory[]
  salaries           Salary[]
  leaveRequests      LeaveRequest[]
  inventoryItems     InventoryItem[]
  supportTickets     SupportTicket[]
  auditLogs          AuditLog[]
  subscriptionInvoices SubscriptionInvoice[]
  teacherAssignments TeacherAssignment[]
}

model User {
  id             String    @id @default(uuid())
  instituteId    String?
  institute      Institute? @relation(fields: [instituteId], references: [id])
  email          String    @unique @db.VarChar(200)
  passwordHash   String    @db.VarChar(500)
  firstName      String?   @db.VarChar(100)
  lastName       String?   @db.VarChar(100)
  role           UserRole
  isActive       Boolean   @default(true)
  mustChangePass Boolean   @default(false)
  lastLoginAt    DateTime?
  lastLoginIp    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  student        Student?
  teacher        Teacher?
  loginHistory   LoginHistory[]
  ticketsCreated SupportTicket[] @relation("TicketCreator")
  ticketReplies  TicketReply[]
  auditLogs      AuditLog[]
  attendanceMarked Attendance[] @relation("MarkedBy")
  feesCollected  Fee[]         @relation("CollectedBy")
  invoicesCreated SubscriptionInvoice[] @relation("InvoiceCreator")
  leaveRequests  LeaveRequest[]
  assignments    Assignment[]

  @@index([instituteId, role])
  @@index([email])
}

// ─── Academic Structure ──────────────────────────────────────────────────────

model Department {
  id          String    @id @default(uuid())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  name        String    @db.VarChar(200)
  code        String?   @db.VarChar(20)
  createdAt   DateTime  @default(now())

  courses Course[]

  @@index([instituteId])
}

model Course {
  id           String     @id @default(uuid())
  instituteId  String
  institute    Institute  @relation(fields: [instituteId], references: [id])
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])
  name         String     @db.VarChar(200)
  code         String?    @db.VarChar(20)
  creditHours  Int        @default(0)
  createdAt    DateTime   @default(now())

  subjects Subject[]

  @@index([instituteId])
}

model Subject {
  id          String    @id @default(uuid())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  courseId    String
  course      Course    @relation(fields: [courseId], references: [id])
  name        String    @db.VarChar(200)
  code        String?   @db.VarChar(20)
  creditHours Int       @default(0)
  createdAt   DateTime  @default(now())

  attendance Attendance[]
  results    Result[]
  timetable  Timetable[]
  assignments Assignment[]
  teacherAssignments TeacherAssignment[]

  @@index([instituteId])
}

model Session {
  id          String    @id @default(uuid())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  name        String    @db.VarChar(100)
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean   @default(false)
  createdAt   DateTime  @default(now())

  semesters Semester[]
  batches   Batch[]

  @@index([instituteId])
}

model Semester {
  id          String    @id @default(uuid())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  sessionId   String
  session     Session   @relation(fields: [sessionId], references: [id])
  name        String    @db.VarChar(100)
  number      Int
  startDate   DateTime
  endDate     DateTime
  createdAt   DateTime  @default(now())

  exams Exam[]

  @@index([instituteId])
}

model Batch {
  id          String    @id @default(uuid())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  sessionId   String?
  session     Session?  @relation(fields: [sessionId], references: [id])
  name        String    @db.VarChar(100)
  year        Int?
  createdAt   DateTime  @default(now())

  sections Section[]
  students Student[]

  @@index([instituteId])
}

model Section {
  id          String    @id @default(uuid())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  batchId     String
  batch       Batch     @relation(fields: [batchId], references: [id])
  name        String    @db.VarChar(50)
  capacity    Int?
  createdAt   DateTime  @default(now())

  students Student[]
  teacherAssignments TeacherAssignment[]
  exams    Exam[]
  timetable Timetable[]

  @@index([instituteId])
}

// ─── People ──────────────────────────────────────────────────────────────────

model Student {
  id               String        @id @default(uuid())
  instituteId      String
  institute        Institute     @relation(fields: [instituteId], references: [id])
  userId           String?       @unique
  user             User?         @relation(fields: [userId], references: [id])
  rollNumber       String?       @db.VarChar(50)
  firstName        String        @db.VarChar(100)
  lastName         String        @db.VarChar(100)
  dateOfBirth      DateTime?     @db.Date
  gender           Gender?
  cnic             String?       @db.VarChar(15)
  phone            String?       @db.VarChar(20)
  address          String?
  photo            String?       @db.VarChar(500)
  guardianName     String?       @db.VarChar(200)
  guardianPhone    String?       @db.VarChar(20)
  enrollmentDate   DateTime?     @db.Date
  status           StudentStatus @default(ACTIVE)
  currentBatchId   String?
  currentBatch     Batch?        @relation(fields: [currentBatchId], references: [id])
  currentSectionId String?
  currentSection   Section?      @relation(fields: [currentSectionId], references: [id])
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  attendance          Attendance[]
  fees                Fee[]
  results             Result[]
  submissions         Submission[]
  libraryIssues       LibraryIssue[]
  hostelAllotments    HostelAllotment[]
  transportAllotments TransportAllotment[]
  certificates        Certificate[]

  @@unique([instituteId, rollNumber])
  @@index([instituteId])
}

model Teacher {
  id             String        @id @default(uuid())
  instituteId    String
  institute      Institute     @relation(fields: [instituteId], references: [id])
  userId         String?       @unique
  user           User?         @relation(fields: [userId], references: [id])
  employeeCode   String?       @db.VarChar(50)
  firstName      String        @db.VarChar(100)
  lastName       String        @db.VarChar(100)
  qualification  String?       @db.VarChar(200)
  specialization String?       @db.VarChar(200)
  joiningDate    DateTime?     @db.Date
  salary         Decimal?      @db.Decimal(10, 2)
  status         TeacherStatus @default(ACTIVE)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  timetable     Timetable[]
  salaries      Salary[]
  leaveRequests LeaveRequest[]
  assignments   TeacherAssignment[]

  @@index([instituteId])
}

model TeacherAssignment {
  id          String    @id @default(uuid())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  teacherId   String
  teacher     Teacher   @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subjectId   String
  subject     Subject   @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  sectionId   String
  section     Section   @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([instituteId, teacherId, subjectId, sectionId])
  @@index([instituteId, teacherId])
  @@index([instituteId, sectionId])
}

// ─── Academic Operations ─────────────────────────────────────────────────────

model Attendance {
  id            String           @id @default(uuid())
  instituteId   String
  institute     Institute        @relation(fields: [instituteId], references: [id])
  studentId     String
  student       Student          @relation(fields: [studentId], references: [id])
  subjectId     String
  subject       Subject          @relation(fields: [subjectId], references: [id])
  date          DateTime         @db.Date
  lectureNumber Int              @default(1)
  status        AttendanceStatus
  markedById    String?
  markedBy      User?            @relation("MarkedBy", fields: [markedById], references: [id])
  createdAt     DateTime         @default(now())

  @@unique([instituteId, studentId, subjectId, date, lectureNumber])
  @@index([instituteId, studentId, date])
}

model Exam {
  id             String    @id @default(uuid())
  instituteId    String
  institute      Institute @relation(fields: [instituteId], references: [id])
  name           String    @db.VarChar(200)
  examType       ExamType  @default(FINAL)
  sectionId      String?
  section        Section?  @relation(fields: [sectionId], references: [id])
  semesterId     String?
  semester       Semester? @relation(fields: [semesterId], references: [id])
  startDate      DateTime?
  endDate        DateTime?
  theoryMax      Decimal   @default(75) @db.Decimal(5, 2)
  practicalMax   Decimal   @default(15) @db.Decimal(5, 2)
  internalMax    Decimal   @default(10) @db.Decimal(5, 2)
  passPercentage Decimal   @default(33) @db.Decimal(5, 2)
  isPublished    Boolean   @default(false)
  createdAt      DateTime  @default(now())

  results Result[]

  @@index([instituteId])
}

model Result {
  id             String    @id @default(uuid())
  instituteId    String
  institute      Institute @relation(fields: [instituteId], references: [id])
  studentId      String
  student        Student   @relation(fields: [studentId], references: [id])
  subjectId      String
  subject        Subject   @relation(fields: [subjectId], references: [id])
  examId         String
  exam           Exam      @relation(fields: [examId], references: [id])
  theoryMarks    Decimal?  @db.Decimal(5, 2)
  practicalMarks Decimal?  @db.Decimal(5, 2)
  internalMarks  Decimal?  @db.Decimal(5, 2)
  totalMarks     Decimal?  @db.Decimal(5, 2)
  maxMarks       Decimal?  @db.Decimal(5, 2)
  grade          String?   @db.VarChar(5)
  gradePoints    Decimal?  @db.Decimal(3, 2)
  isPassed       Boolean?
  publishedAt    DateTime?
  createdAt      DateTime  @default(now())

  @@unique([instituteId, studentId, subjectId, examId])
  @@index([instituteId])
}

model Timetable {
  id          String    @id @default(uuid())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  subjectId   String
  subject     Subject   @relation(fields: [subjectId], references: [id])
  sectionId   String?
  section     Section?  @relation(fields: [sectionId], references: [id])
  teacherId   String?
  teacher     Teacher?  @relation(fields: [teacherId], references: [id])
  dayOfWeek   Int
  startTime   String    @db.VarChar(10)
  endTime     String    @db.VarChar(10)
  room        String?   @db.VarChar(50)
  createdAt   DateTime  @default(now())

  @@index([instituteId])
}

model Assignment {
  id          String    @id @default(uuid())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  subjectId   String
  subject     Subject   @relation(fields: [subjectId], references: [id])
  teacherId   String
  teacher     User      @relation(fields: [teacherId], references: [id])
  title       String    @db.VarChar(300)
  description String?
  dueDate     DateTime?
  maxMarks    Decimal?  @db.Decimal(5, 2)
  createdAt   DateTime  @default(now())

  submissions Submission[]

  @@index([instituteId])
}

model Submission {
  id           String     @id @default(uuid())
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id])
  studentId    String
  student      Student    @relation(fields: [studentId], references: [id])
  content      String?
  attachment   String?    @db.VarChar(500)
  marks        Decimal?   @db.Decimal(5, 2)
  submittedAt  DateTime   @default(now())

  @@unique([assignmentId, studentId])
}

// ─── Finance ─────────────────────────────────────────────────────────────────

model FeeStructure {
  id          String    @id @default(uuid())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  name        String    @db.VarChar(200)
  amount      Decimal   @db.Decimal(10, 2)
  frequency   String?   @db.VarChar(50)
  createdAt   DateTime  @default(now())

  fees Fee[]

  @@index([instituteId])
}

model Fee {
  id             String       @id @default(uuid())
  instituteId    String
  institute      Institute    @relation(fields: [instituteId], references: [id])
  studentId      String
  student        Student      @relation(fields: [studentId], references: [id])
  feeStructureId String
  feeStructure   FeeStructure @relation(fields: [feeStructureId], references: [id])
  amount         Decimal      @db.Decimal(10, 2)
  fine           Decimal      @default(0) @db.Decimal(10, 2)
  discount       Decimal      @default(0) @db.Decimal(10, 2)
  dueDate        DateTime?    @db.Date
  paidDate       DateTime?    @db.Date
  status         FeeStatus    @default(PENDING)
  receiptNumber  String?      @db.VarChar(50)
  collectedById  String?
  collectedBy    User?        @relation("CollectedBy", fields: [collectedById], references: [id])
  createdAt      DateTime     @default(now())

  @@index([instituteId, studentId])
  @@index([instituteId, status])
}

model SubscriptionInvoice {
  id            String           @id @default(uuid())
  invoiceNumber String           @unique @db.VarChar(50)
  instituteId   String
  institute     Institute        @relation(fields: [instituteId], references: [id])
  planId        String
  plan          SubscriptionPlan @relation(fields: [planId], references: [id])
  type          InvoiceType
  amount        Decimal          @db.Decimal(10, 2)
  status        InvoiceStatus    @default(PENDING)
  issuedAt      DateTime         @default(now())
  dueDate       DateTime?
  paidAt        DateTime?
  paymentRef    String?          @db.VarChar(200)
  paymentProof  String?          @db.VarChar(500)
  periodFrom    DateTime?
  periodTo      DateTime?
  notes         String?
  createdById   String?
  createdBy     User?            @relation("InvoiceCreator", fields: [createdById], references: [id])
  createdAt     DateTime         @default(now())

  @@index([instituteId])
}

// ─── Support & Audit ─────────────────────────────────────────────────────────

model SupportTicket {
  id          String         @id @default(uuid())
  instituteId String
  institute   Institute      @relation(fields: [instituteId], references: [id])
  createdById String
  createdBy   User           @relation("TicketCreator", fields: [createdById], references: [id])
  subject     String         @db.VarChar(300)
  category    TicketCategory
  description String
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(MEDIUM)
  closedAt    DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  replies TicketReply[]

  @@index([instituteId])
  @@index([status])
}

model TicketReply {
  id          String        @id @default(uuid())
  ticketId    String
  ticket      SupportTicket @relation(fields: [ticketId], references: [id])
  repliedById String
  repliedBy   User          @relation(fields: [repliedById], references: [id])
  message     String
  attachments String[]
  createdAt   DateTime      @default(now())
}

model AuditLog {
  id          String     @id @default(uuid())
  instituteId String?
  institute   Institute? @relation(fields: [instituteId], references: [id])
  userId      String?
  user        User?      @relation(fields: [userId], references: [id])
  action      String     @db.VarChar(100)
  entity      String     @db.VarChar(50)
  entityId    String?
  oldValue    Json?
  newValue    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime   @default(now())

  @@index([instituteId, createdAt])
  @@index([userId, createdAt])
}

model LoginHistory {
  id          String     @id @default(uuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id])
  instituteId String?
  institute   Institute? @relation(fields: [instituteId], references: [id])
  ipAddress   String?
  userAgent   String?
  success     Boolean    @default(true)
  createdAt   DateTime   @default(now())

  @@index([userId, createdAt])
  @@index([instituteId, createdAt])
}

// ─── Optional Modules (stubs) ─────────────────────────────────────────────────

model LibraryBook {
  id          String    @id @default(uuid())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  title       String    @db.VarChar(300)
  author      String?   @db.VarChar(200)
  isbn        String?   @db.VarChar(20)
  copies      Int       @default(1)
  createdAt   DateTime  @default(now())

  issues LibraryIssue[]

  @@index([instituteId])
}

model LibraryIssue {
  id          String      @id @default(uuid())
  instituteId String
  institute   Institute   @relation(fields: [instituteId], references: [id])
  bookId      String
  book        LibraryBook @relation(fields: [bookId], references: [id])
  studentId   String
  student     Student     @relation(fields: [studentId], references: [id])
  issuedAt    DateTime    @default(now())
  dueDate     DateTime?
  returnedAt  DateTime?

  @@index([instituteId])
}

model HostelRoom {
  id          String    @id @default(uuid())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  roomNumber  String    @db.VarChar(20)
  capacity    Int       @default(1)
  createdAt   DateTime  @default(now())

  allotments HostelAllotment[]

  @@index([instituteId])
}

model HostelAllotment {
  id          String     @id @default(uuid())
  instituteId String
  institute   Institute  @relation(fields: [instituteId], references: [id])
  roomId      String
  room        HostelRoom @relation(fields: [roomId], references: [id])
  studentId   String
  student     Student    @relation(fields: [studentId], references: [id])
  startDate   DateTime?
  endDate     DateTime?

  @@index([instituteId])
}

model TransportRoute {
  id          String    @id @default(uuid())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  name        String    @db.VarChar(200)
  stops       String[]
  createdAt   DateTime  @default(now())

  allotments TransportAllotment[]

  @@index([instituteId])
}

model TransportAllotment {
  id          String         @id @default(uuid())
  instituteId String
  institute   Institute      @relation(fields: [instituteId], references: [id])
  routeId     String
  route       TransportRoute @relation(fields: [routeId], references: [id])
  studentId   String
  student     Student        @relation(fields: [studentId], references: [id])

  @@index([instituteId])
}

model Notification {
  id          String    @id @default(uuid())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  title       String    @db.VarChar(300)
  message     String
  channel     String    @db.VarChar(20)
  status      String    @default("PENDING") @db.VarChar(20)
  createdAt   DateTime  @default(now())

  @@index([instituteId])
}

model Announcement {
  id          String    @id @default(uuid())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  title       String    @db.VarChar(300)
  content     String
  publishedAt DateTime  @default(now())

  @@index([instituteId])
}

model CardDesign {
  id          String    @id @default(uuid())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  fileUrl     String    @db.VarChar(500)
  type        String    @db.VarChar(50)
  createdAt   DateTime  @default(now())

  @@index([instituteId])
}

model Certificate {
  id          String    @id @default(uuid())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  studentId   String
  student     Student   @relation(fields: [studentId], references: [id])
  type        String    @db.VarChar(100)
  fileUrl     String?   @db.VarChar(500)
  issuedAt    DateTime  @default(now())

  @@index([instituteId])
}

model Salary {
  id          String    @id @default(uuid())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  teacherId   String
  teacher     Teacher   @relation(fields: [teacherId], references: [id])
  month       Int
  year        Int
  amount      Decimal   @db.Decimal(10, 2)
  deductions  Decimal   @default(0) @db.Decimal(10, 2)
  netAmount   Decimal   @db.Decimal(10, 2)
  createdAt   DateTime  @default(now())

  @@index([instituteId])
}

model LeaveRequest {
  id          String    @id @default(uuid())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  teacherId   String?
  teacher     Teacher?  @relation(fields: [teacherId], references: [id])
  leaveType   String    @db.VarChar(50)
  startDate   DateTime  @db.Date
  endDate     DateTime  @db.Date
  reason      String?
  status      String    @default("PENDING") @db.VarChar(20)
  createdAt   DateTime  @default(now())

  @@index([instituteId])
}

model InventoryItem {
  id          String    @id @default(uuid())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  name        String    @db.VarChar(200)
  quantity    Int       @default(0)
  unit        String?   @db.VarChar(20)
  createdAt   DateTime  @default(now())

  @@index([instituteId])
}
