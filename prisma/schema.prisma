// ─── Soft-delete & archival (applied to high-churn entities) ─────────────────

// Student, Teacher: add via migration
// deletedAt DateTime?  archivedAt DateTime?

// ─── Guardians & parent portal ───────────────────────────────────────────────

model Guardian {
  id          String    @id @default(uuid())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  userId      String?   @unique
  user        User?     @relation(fields: [userId], references: [id])
  firstName   String    @db.VarChar(100)
  lastName    String    @db.VarChar(100)
  email       String?   @db.VarChar(200)
  phone       String?   @db.VarChar(20)
  cnic        String?   @db.VarChar(15)
  address     String?
  relation    String?   @db.VarChar(50)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  studentLinks ParentStudentLink[]

  @@index([instituteId])
  @@index([instituteId, deletedAt])
}

model ParentStudentLink {
  id          String    @id @default(uuid())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  guardianId  String
  guardian    Guardian  @relation(fields: [guardianId], references: [id], onDelete: Cascade)
  studentId   String
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  isPrimary   Boolean   @default(false)
  canPickup   Boolean   @default(true)
  createdAt   DateTime  @default(now())

  @@unique([instituteId, guardianId, studentId])
  @@index([instituteId, studentId])
}

// ─── Campus & facilities ───────────────────────────────────────────────────────

model Building {
  id          String    @id @default(uuid())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  name        String    @db.VarChar(200)
  code        String?   @db.VarChar(20)
  address     String?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())

  classrooms Classroom[]

  @@unique([instituteId, code])
  @@index([instituteId, deletedAt])
}

model Classroom {
  id          String    @id @default(uuid())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  buildingId  String
  building    Building  @relation(fields: [buildingId], references: [id])
  name        String    @db.VarChar(100)
  code        String?   @db.VarChar(20)
  capacity    Int?
  floor       Int?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())

  rooms Room[]

  @@index([instituteId, buildingId])
}

model Room {
  id          String    @id @default(uuid())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  classroomId String?
  classroom   Classroom? @relation(fields: [classroomId], references: [id])
  name        String    @db.VarChar(100)
  roomType    String    @db.VarChar(50)
  capacity    Int?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([instituteId])
}

model AcademicCalendarEvent {
  id          String    @id @default(uuid())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  title       String    @db.VarChar(300)
  description String?
  eventType   String    @db.VarChar(50)
  startDate   DateTime
  endDate     DateTime?
  isHoliday   Boolean   @default(false)
  sessionId   String?
  session     Session?  @relation(fields: [sessionId], references: [id])
  createdAt   DateTime  @default(now())

  @@index([instituteId, startDate])
}

// ─── Hostel hierarchy ──────────────────────────────────────────────────────────

model HostelBlock {
  id          String    @id @default(uuid())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  name        String    @db.VarChar(100)
  code        String?   @db.VarChar(20)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())

  floors HostelFloor[]

  @@index([instituteId])
}

model HostelFloor {
  id          String      @id @default(uuid())
  instituteId String
  institute   Institute   @relation(fields: [instituteId], references: [id])
  blockId     String
  block       HostelBlock @relation(fields: [blockId], references: [id])
  floorNumber Int
  name        String?     @db.VarChar(50)
  createdAt   DateTime    @default(now())

  rooms HostelRoomExtended[]

  @@unique([blockId, floorNumber])
  @@index([instituteId])
}

model HostelRoomExtended {
  id          String      @id @default(uuid())
  instituteId String
  institute   Institute   @relation(fields: [instituteId], references: [id])
  floorId     String
  floor       HostelFloor @relation(fields: [floorId], references: [id])
  roomNumber  String      @db.VarChar(20)
  capacity    Int         @default(1)
  deletedAt   DateTime?
  createdAt   DateTime    @default(now())

  @@unique([instituteId, floorId, roomNumber])
}

// ─── Transport hierarchy ─────────────────────────────────────────────────────

model Bus {
  id           String    @id @default(uuid())
  instituteId  String
  institute    Institute @relation(fields: [instituteId], references: [id])
  registration String    @db.VarChar(50)
  capacity     Int
  driverName   String?   @db.VarChar(100)
  driverPhone  String?   @db.VarChar(20)
  isActive     Boolean   @default(true)
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())

  routeAssignments RouteBus[]

  @@unique([instituteId, registration])
  @@index([instituteId])
}

model TransportStop {
  id          String    @id @default(uuid())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  name        String    @db.VarChar(200)
  latitude    Decimal?  @db.Decimal(10, 7)
  longitude   Decimal?  @db.Decimal(10, 7)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())

  routeStops RouteStop[]

  @@index([instituteId])
}

model RouteStop {
  id          String         @id @default(uuid())
  instituteId String
  institute   Institute      @relation(fields: [instituteId], references: [id])
  routeId     String
  route       TransportRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)
  stopId      String
  stop        TransportStop  @relation(fields: [stopId], references: [id])
  sequence    Int
  pickupTime  String?        @db.VarChar(10)

  @@unique([routeId, stopId])
  @@index([instituteId, routeId])
}

model RouteBus {
  id          String         @id @default(uuid())
  instituteId String
  institute   Institute      @relation(fields: [instituteId], references: [id])
  routeId     String
  route       TransportRoute @relation(fields: [routeId], references: [id])
  busId       String
  bus         Bus            @relation(fields: [busId], references: [id])
  assignedAt  DateTime       @default(now())

  @@unique([routeId, busId])
}

// ─── LMS / Quiz ──────────────────────────────────────────────────────────────

model QuestionBank {
  id          String    @id @default(uuid())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  subjectId   String?
  subject     Subject?  @relation(fields: [subjectId], references: [id])
  question    String
  questionType String   @db.VarChar(30)
  options     Json?
  correctAnswer Json?
  marks       Decimal   @default(1) @db.Decimal(5, 2)
  difficulty  String?   @db.VarChar(20)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())

  quizLinks QuizQuestion[]

  @@index([instituteId, subjectId])
}

model Quiz {
  id          String    @id @default(uuid())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  title       String    @db.VarChar(300)
  description String?
  durationMin Int?
  maxAttempts Int       @default(1)
  isPublished Boolean   @default(false)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())

  questions QuizQuestion[]
  answers   QuizAnswer[]

  @@index([instituteId])
}

model QuizQuestion {
  id         String       @id @default(uuid())
  quizId     String
  quiz       Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  questionId String
  question   QuestionBank @relation(fields: [questionId], references: [id])
  sortOrder  Int          @default(0)

  @@unique([quizId, questionId])
}

model QuizAnswer {
  id          String    @id @default(uuid())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  quizId      String
  quiz        Quiz      @relation(fields: [quizId], references: [id])
  studentId   String
  student     Student   @relation(fields: [studentId], references: [id])
  answers     Json
  score       Decimal?  @db.Decimal(5, 2)
  attemptNo   Int       @default(1)
  submittedAt DateTime  @default(now())

  @@index([instituteId, quizId, studentId])
}

model AssignmentFile {
  id           String     @id @default(uuid())
  instituteId  String
  institute    Institute  @relation(fields: [instituteId], references: [id])
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  fileName     String     @db.VarChar(300)
  url          String     @db.VarChar(500)
  mimeType     String?    @db.VarChar(100)
  fileSize     Int?
  uploadedAt   DateTime   @default(now())

  @@index([assignmentId])
}

// ─── Inventory & procurement ─────────────────────────────────────────────────

model Vendor {
  id          String    @id @default(uuid())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  name        String    @db.VarChar(200)
  contact     String?   @db.VarChar(200)
  phone       String?   @db.VarChar(20)
  email       String?   @db.VarChar(200)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())

  purchaseOrders PurchaseOrder[]

  @@index([instituteId])
}

model PurchaseOrder {
  id          String              @id @default(uuid())
  instituteId String
  institute   Institute           @relation(fields: [instituteId], references: [id])
  vendorId    String
  vendor      Vendor              @relation(fields: [vendorId], references: [id])
  poNumber    String              @db.VarChar(50)
  status      PurchaseOrderStatus @default(DRAFT)
  totalAmount Decimal             @default(0) @db.Decimal(12, 2)
  notes       String?
  deletedAt   DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  lines PurchaseOrderLine[]

  @@unique([instituteId, poNumber])
  @@index([instituteId, status])
}

model PurchaseOrderLine {
  id              String        @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  inventoryItemId String?
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id])
  description     String        @db.VarChar(300)
  quantity        Int
  unitPrice       Decimal       @db.Decimal(10, 2)
  lineTotal       Decimal       @db.Decimal(12, 2)

  @@index([purchaseOrderId])
}

model InventoryTransaction {
  id              String           @id @default(uuid())
  instituteId     String
  institute       Institute        @relation(fields: [instituteId], references: [id])
  inventoryItemId String
  inventoryItem   InventoryItem    @relation(fields: [inventoryItemId], references: [id])
  txnType         InventoryTxnType
  quantity        Int
  reference       String?          @db.VarChar(100)
  notes           String?
  performedById   String?
  performedBy     User?            @relation("InventoryTxnBy", fields: [performedById], references: [id])
  createdAt       DateTime         @default(now())

  @@index([instituteId, inventoryItemId, createdAt])
}

model Asset {
  id          String      @id @default(uuid())
  instituteId String
  institute   Institute   @relation(fields: [instituteId], references: [id])
  tagNumber   String      @db.VarChar(50)
  name        String      @db.VarChar(200)
  category    String?     @db.VarChar(100)
  status      AssetStatus @default(ACTIVE)
  purchaseDate DateTime?  @db.Date
  value       Decimal?    @db.Decimal(12, 2)
  location    String?     @db.VarChar(200)
  deletedAt   DateTime?
  createdAt   DateTime    @default(now())

  maintenanceRecords MaintenanceRecord[]

  @@unique([instituteId, tagNumber])
  @@index([instituteId, status])
}

model MaintenanceRecord {
  id          String    @id @default(uuid())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  assetId     String
  asset       Asset     @relation(fields: [assetId], references: [id])
  description String
  cost        Decimal?  @db.Decimal(10, 2)
  performedAt DateTime  @default(now())
  nextDueAt   DateTime?

  @@index([instituteId, assetId])
}

// ─── Payroll expansion ─────────────────────────────────────────────────────────

model SalaryComponent {
  id          String    @id @default(uuid())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  code        String    @db.VarChar(30)
  name        String    @db.VarChar(100)
  isDeduction Boolean   @default(false)
  isTaxable   Boolean   @default(true)
  createdAt   DateTime  @default(now())

  payrollDetails PayrollDetail[]

  @@unique([instituteId, code])
}

model PayrollDetail {
  id                String          @id @default(uuid())
  instituteId       String
  institute         Institute       @relation(fields: [instituteId], references: [id])
  salaryId          String
  salary            Salary          @relation(fields: [salaryId], references: [id], onDelete: Cascade)
  salaryComponentId String
  salaryComponent   SalaryComponent @relation(fields: [salaryComponentId], references: [id])
  amount            Decimal         @db.Decimal(10, 2)

  @@index([salaryId])
}

model LeaveBalance {
  id          String    @id @default(uuid())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  leaveType   String    @db.VarChar(50)
  year        Int
  allocated   Decimal   @db.Decimal(5, 1)
  used        Decimal   @default(0) @db.Decimal(5, 1)
  remaining   Decimal   @db.Decimal(5, 1)

  @@unique([instituteId, userId, leaveType, year])
  @@index([instituteId, userId])
}

model BiometricLog {
  id          String    @id @default(uuid())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  userId      String?
  user        User?     @relation(fields: [userId], references: [id])
  studentId   String?
  student     Student?  @relation(fields: [studentId], references: [id])
  deviceId    String    @db.VarChar(100)
  punchType   String    @db.VarChar(20)
  punchedAt   DateTime
  rawPayload  Json?

  @@index([instituteId, punchedAt])
  @@index([instituteId, userId, punchedAt])
}

// ─── Notifications & comms logs ──────────────────────────────────────────────

model NotificationRead {
  id             String   @id @default(uuid())
  notificationId String
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  readAt         DateTime @default(now())

  @@unique([notificationId, userId])
}

model EmailLog {
  id          String    @id @default(uuid())
  instituteId String?
  institute   Institute? @relation(fields: [instituteId], references: [id])
  toEmail     String    @db.VarChar(200)
  subject     String    @db.VarChar(300)
  template    String?   @db.VarChar(100)
  status      String    @db.VarChar(20)
  providerRef String?   @db.VarChar(200)
  error       String?
  sentAt      DateTime  @default(now())

  @@index([instituteId, sentAt])
}

model SmsLog {
  id          String    @id @default(uuid())
  instituteId String?
  institute   Institute? @relation(fields: [instituteId], references: [id])
  toPhone     String    @db.VarChar(20)
  message     String
  status      String    @db.VarChar(20)
  providerRef String?   @db.VarChar(200)
  sentAt      DateTime  @default(now())

  @@index([instituteId, sentAt])
}

model FileStorageRecord {
  id          String    @id @default(uuid())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  entityType  String    @db.VarChar(50)
  entityId    String?
  fileName    String    @db.VarChar(300)
  storageKey  String    @db.VarChar(500)
  provider    String    @db.VarChar(30)
  sizeBytes   BigInt    @default(0)
  mimeType    String?   @db.VarChar(100)
  checksum    String?   @db.VarChar(64)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())

  versions DocumentVersion[]

  @@index([instituteId, entityType, entityId])
  @@index([instituteId, createdAt])
}

// ─── Platform config ───────────────────────────────────────────────────────────

model FeatureFlag {
  id          String   @id @default(uuid())
  key         String   @unique @db.VarChar(100)
  description String?
  defaultOn   Boolean  @default(false)
  rules       Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  overrides InstituteFeatureFlag[]
}

model InstituteFeatureFlag {
  id          String      @id @default(uuid())
  instituteId String
  institute   Institute   @relation(fields: [instituteId], references: [id])
  flagId      String
  flag        FeatureFlag @relation(fields: [flagId], references: [id])
  enabled     Boolean
  config      Json?

  @@unique([instituteId, flagId])
}

model InstituteTheme {
  id          String    @id @default(uuid())
  instituteId String    @unique
  institute   Institute @relation(fields: [instituteId], references: [id])
  primaryColor String   @db.VarChar(20)
  secondaryColor String? @db.VarChar(20)
  fontFamily  String?   @db.VarChar(100)
  customCss   String?
  updatedAt   DateTime  @updatedAt
}

model InstituteBranding {
  id          String    @id @default(uuid())
  instituteId String    @unique
  institute   Institute @relation(fields: [instituteId], references: [id])
  logoUrl     String?   @db.VarChar(500)
  faviconUrl  String?   @db.VarChar(500)
  letterhead  String?   @db.VarChar(500)
  watermark   String?   @db.VarChar(500)
  updatedAt   DateTime  @updatedAt
}

model BackupRecord {
  id          String       @id @default(uuid())
  scope       String       @db.VarChar(30)
  instituteId String?
  institute   Institute?   @relation(fields: [instituteId], references: [id])
  storagePath String       @db.VarChar(500)
  sizeBytes   BigInt?
  status      BackupStatus @default(PENDING)
  verifiedAt  DateTime?
  rpoMinutes  Int?
  rtoMinutes  Int?
  region      String?      @db.VarChar(50)
  createdAt   DateTime     @default(now())

  @@index([scope, createdAt])
}

model Webhook {
  id          String        @id @default(uuid())
  instituteId String
  institute   Institute     @relation(fields: [instituteId], references: [id])
  name        String        @db.VarChar(100)
  url         String        @db.VarChar(500)
  secretHash  String        @db.VarChar(200)
  events      String[]
  status      WebhookStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())

  deliveries WebhookDelivery[]

  @@index([instituteId])
}

model WebhookDelivery {
  id           String   @id @default(uuid())
  webhookId    String
  webhook      Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  eventType    String   @db.VarChar(100)
  payload      Json
  responseCode Int?
  responseBody String?
  attempt      Int      @default(1)
  deliveredAt  DateTime @default(now())

  @@index([webhookId, deliveredAt])
}

model ActivityStream {
  id          String    @id @default(uuid())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  actorId     String?
  actor       User?     @relation("ActivityActor", fields: [actorId], references: [id])
  verb        String    @db.VarChar(50)
  objectType  String    @db.VarChar(50)
  objectId    String?
  summary     String?   @db.VarChar(500)
  metadata    Json?
  createdAt   DateTime  @default(now())

  @@index([instituteId, createdAt])
}

model ApiKey {
  id          String    @id @default(uuid())
  instituteId String?
  institute   Institute? @relation(fields: [instituteId], references: [id])
  name        String    @db.VarChar(100)
  keyPrefix   String    @db.VarChar(12)
  keyHash     String    @db.VarChar(200)
  scopes      String[]
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdById String?
  createdBy   User?     @relation("ApiKeyCreator", fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())

  @@index([keyPrefix])
  @@index([instituteId])
}

// ─── Workflow engine ───────────────────────────────────────────────────────────

model WorkflowDefinition {
  id          String       @id @default(uuid())
  instituteId String?
  institute   Institute?   @relation(fields: [instituteId], references: [id])
  workflowType WorkflowType
  name        String       @db.VarChar(200)
  version     Int          @default(1)
  isActive    Boolean      @default(true)
  config      Json?
  createdAt   DateTime     @default(now())

  states      WorkflowState[]
  transitions WorkflowTransition[]
  instances   WorkflowInstance[]

  @@unique([instituteId, workflowType, version])
}

model WorkflowState {
  id           String             @id @default(uuid())
  definitionId String
  definition   WorkflowDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  key          String             @db.VarChar(50)
  label        String             @db.VarChar(100)
  isInitial    Boolean            @default(false)
  isTerminal   Boolean            @default(false)
  sortOrder    Int                @default(0)

  @@unique([definitionId, key])
}

model WorkflowTransition {
  id              String             @id @default(uuid())
  definitionId    String
  definition      WorkflowDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  fromStateKey    String             @db.VarChar(50)
  toStateKey      String             @db.VarChar(50)
  action          String             @db.VarChar(50)
  requiredRole    String?            @db.VarChar(50)
  escalationHours Int?
  conditions      Json?

  @@index([definitionId])
}

model WorkflowInstance {
  id           String                 @id @default(uuid())
  instituteId  String
  institute    Institute              @relation(fields: [instituteId], references: [id])
  definitionId String
  definition   WorkflowDefinition     @relation(fields: [definitionId], references: [id])
  workflowType WorkflowType
  entityType   String                 @db.VarChar(50)
  entityId     String
  currentState String                 @db.VarChar(50)
  status       WorkflowInstanceStatus @default(IN_PROGRESS)
  initiatedById String?
  initiatedBy  User?                  @relation("WorkflowInitiator", fields: [initiatedById], references: [id])
  metadata     Json?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  completedAt  DateTime?

  approvals WorkflowApproval[]
  auditLogs WorkflowAuditLog[]

  @@index([instituteId, workflowType, status])
  @@index([instituteId, entityType, entityId])
}

model WorkflowApproval {
  id           String           @id @default(uuid())
  instanceId   String
  instance     WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  stepKey      String           @db.VarChar(50)
  approverId   String?
  approver     User?            @relation("WorkflowApprover", fields: [approverId], references: [id])
  decision     ApprovalDecision @default(PENDING)
  comments     String?
  decidedAt    DateTime?
  escalatedAt  DateTime?
  dueAt        DateTime?

  @@index([instanceId])
  @@index([approverId, decision])
}

model WorkflowAuditLog {
  id         String           @id @default(uuid())
  instanceId String
  instance   WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  fromState  String?          @db.VarChar(50)
  toState    String           @db.VarChar(50)
  action     String           @db.VarChar(50)
  actorId    String?
  actor      User?            @relation("WorkflowAuditActor", fields: [actorId], references: [id])
  metadata   Json?
  createdAt  DateTime         @default(now())

  @@index([instanceId, createdAt])
}

// ─── Dynamic form builder ──────────────────────────────────────────────────────

model FormDefinition {
  id          String      @id @default(uuid())
  instituteId String
  institute   Institute   @relation(fields: [instituteId], references: [id])
  name        String      @db.VarChar(200)
  purpose     FormPurpose
  slug        String      @db.VarChar(100)
  version     Int         @default(1)
  isPublished Boolean     @default(false)
  schema      Json?
  deletedAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  fields      FormField[]
  submissions FormSubmission[]

  @@unique([instituteId, slug, version])
  @@index([instituteId, purpose])
}

model FormField {
  id         String        @id @default(uuid())
  formId     String
  form       FormDefinition @relation(fields: [formId], references: [id], onDelete: Cascade)
  fieldKey   String        @db.VarChar(100)
  label      String        @db.VarChar(200)
  fieldType  FormFieldType
  required   Boolean       @default(false)
  options    Json?
  validation Json?
  sortOrder  Int           @default(0)
  conditions Json?

  values FormFieldValue[]

  @@unique([formId, fieldKey])
}

model FormSubmission {
  id          String         @id @default(uuid())
  instituteId String
  institute   Institute      @relation(fields: [instituteId], references: [id])
  formId      String
  form        FormDefinition @relation(fields: [formId], references: [id])
  submittedById String?
  submittedBy User?          @relation("FormSubmitter", fields: [submittedById], references: [id])
  status      String         @default("SUBMITTED") @db.VarChar(20)
  metadata    Json?
  createdAt   DateTime       @default(now())

  values FormFieldValue[]

  @@index([instituteId, formId, createdAt])
}

model FormFieldValue {
  id           String         @id @default(uuid())
  submissionId String
  submission   FormSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  fieldId      String
  field        FormField      @relation(fields: [fieldId], references: [id])
  valueText    String?
  valueJson    Json?

  @@unique([submissionId, fieldId])
}

model AbTestExperiment {
  id          String       @id @default(uuid())
  instituteId String?
  institute   Institute?   @relation(fields: [instituteId], references: [id])
  name        String       @db.VarChar(200)
  featureKey  String       @db.VarChar(100)
  status      AbTestStatus @default(DRAFT)
  startAt     DateTime?
  endAt       DateTime?
  config      Json?
  createdAt   DateTime     @default(now())

  variants AbTestVariant[]

  @@index([featureKey, status])
}

model AbTestVariant {
  id           String           @id @default(uuid())
  experimentId String
  experiment   AbTestExperiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  key          String           @db.VarChar(50)
  weight       Int              @default(50)
  payload      Json?
  impressions  Int              @default(0)
  conversions  Int              @default(0)

  @@unique([experimentId, key])
}

// ─── Document versioning ───────────────────────────────────────────────────────

model DocumentVersion {
  id              String             @id @default(uuid())
  instituteId     String
  institute       Institute          @relation(fields: [instituteId], references: [id])
  entityType      DocumentEntityType
  entityId        String
  versionNumber   Int
  storageRecordId String?
  storageRecord   FileStorageRecord? @relation(fields: [storageRecordId], references: [id])
  fileUrl         String?            @db.VarChar(500)
  checksum        String?            @db.VarChar(64)
  changeNotes     String?
  createdById     String?
  createdBy       User?              @relation("DocVersionCreator", fields: [createdById], references: [id])
  isCurrent       Boolean            @default(true)
  createdAt       DateTime           @default(now())

  @@unique([instituteId, entityType, entityId, versionNumber])
  @@index([instituteId, entityType, entityId, isCurrent])
}

// ─── Domain events (event-driven architecture) ───────────────────────────────

model DomainEvent {
  id            String            @id @default(uuid())
  instituteId   String?
  institute     Institute?        @relation(fields: [instituteId], references: [id])
  eventType     String            @db.VarChar(100)
  aggregateType String            @db.VarChar(50)
  aggregateId   String?
  payload       Json
  status        DomainEventStatus @default(PENDING)
  attempts      Int               @default(0)
  lastError     String?
  correlationId String?           @db.VarChar(100)
  causationId   String?           @db.VarChar(100)
  occurredAt    DateTime          @default(now())
  processedAt   DateTime?

  @@index([status, occurredAt])
  @@index([instituteId, eventType, occurredAt])
  @@index([aggregateType, aggregateId])
}

// ─── Security hardening ────────────────────────────────────────────────────────

model UserSession {
  id           String    @id @default(uuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshJti   String?   @db.VarChar(100)
  deviceName   String?   @db.VarChar(200)
  deviceType   String?   @db.VarChar(50)
  ipAddress    String?
  userAgent    String?
  isTrusted    Boolean   @default(false)
  lastActiveAt DateTime  @default(now())
  expiresAt    DateTime
  revokedAt    DateTime?
  createdAt    DateTime  @default(now())

  @@index([userId, revokedAt])
}

model MfaDevice {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  method      MfaMethod
  secretEnc   String?   @db.VarChar(500)
  phone       String?   @db.VarChar(20)
  isVerified  Boolean   @default(false)
  isPrimary   Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@index([userId])
}

model PasswordHistory {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  passwordHash String   @db.VarChar(500)
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
}

model IpWhitelist {
  id          String    @id @default(uuid())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  cidr        String    @db.VarChar(50)
  label       String?   @db.VarChar(100)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  @@index([instituteId, isActive])
}

model LoginAttempt {
  id          String   @id @default(uuid())
  email       String   @db.VarChar(200)
  ipAddress   String?
  success     Boolean
  failReason  String?  @db.VarChar(100)
  attemptedAt DateTime @default(now())

  @@index([email, attemptedAt])
  @@index([ipAddress, attemptedAt])
}

// ─── Compliance & governance ─────────────────────────────────────────────────

model DataConsent {
  id          String      @id @default(uuid())
  instituteId String
  institute   Institute   @relation(fields: [instituteId], references: [id])
  userId      String?
  user        User?       @relation(fields: [userId], references: [id])
  studentId   String?
  student     Student?    @relation(fields: [studentId], references: [id])
  consentType ConsentType
  granted     Boolean
  grantedAt   DateTime?
  revokedAt   DateTime?
  ipAddress   String?
  metadata    Json?

  @@index([instituteId, consentType])
}

model DataRetentionPolicy {
  id            String   @id @default(uuid())
  entityType    String   @db.VarChar(50)
  retentionDays Int
  archiveAfterDays Int?
  purgeAfterDays   Int?
  isActive      Boolean  @default(true)
  updatedAt     DateTime @updatedAt

  @@unique([entityType])
}

model DataExportRequest {
  id          String           @id @default(uuid())
  instituteId String
  institute   Institute        @relation(fields: [instituteId], references: [id])
  requestedById String
  requestedBy User             @relation("ExportRequester", fields: [requestedById], references: [id])
  subjectType String           @db.VarChar(30)
  subjectId   String?
  status      DataExportStatus @default(PENDING)
  fileUrl     String?          @db.VarChar(500)
  expiresAt   DateTime?
  createdAt   DateTime         @default(now())
  completedAt DateTime?

  @@index([instituteId, status])
}

model ErasureRequest {
  id          String        @id @default(uuid())
  instituteId String
  institute   Institute     @relation(fields: [instituteId], references: [id])
  subjectType String        @db.VarChar(30)
  subjectId   String
  status      ErasureStatus @default(REQUESTED)
  requestedById String?
  reviewedById  String?
  notes       String?
  completedAt DateTime?
  createdAt   DateTime      @default(now())

  @@index([instituteId, status])
}

// ─── Analytics snapshots (materialized reporting) ──────────────────────────────

model AnalyticsSnapshot {
  id          String   @id @default(uuid())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  metricKey   String   @db.VarChar(100)
  periodType  String   @db.VarChar(20)
  periodStart DateTime @db.Date
  periodEnd   DateTime @db.Date
  dimensions  Json?
  value       Json
  computedAt  DateTime @default(now())

  @@unique([instituteId, metricKey, periodType, periodStart])
  @@index([instituteId, metricKey, periodStart])
}
