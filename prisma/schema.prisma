generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum InstituteStatus {
  ACTIVE
  SUSPENDED
  BLOCKED
  EXPIRED
}

enum UserRole {
  SUPER_ADMIN
  INSTITUTE_ADMIN
  TEACHER
  STUDENT
  PARENT
  ACCOUNTANT
  HR
  LIBRARIAN
  RECEPTIONIST
  STAFF
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  YEARLY
  CUSTOM
}

enum InvoiceType {
  INITIAL
  RENEWAL
  EXTENSION
}

enum InvoiceStatus {
  PENDING
  PAID
  CANCELLED
}

enum StudentStatus {
  ACTIVE
  ALUMNI
  EXPELLED
  TRANSFERRED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum TeacherStatus {
  ACTIVE
  INACTIVE
  RESIGNED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LEAVE
  LATE
}

enum FeeStatus {
  PENDING
  PAID
  PARTIAL
  WAIVED
}

enum FeeAssignmentScope {
  ALL_STUDENTS
  BATCH
  INDIVIDUAL
}

enum FeeRequestStatus {
  PENDING
  APPROVED
  REJECTED
  PARTIAL_APPROVED
}

enum FeeRequestType {
  INSTALLMENT
  DUE_DATE_EXTENSION
  PARTIAL_PAYMENT
  CONCESSION
}

enum TicketCategory {
  PASSWORD_RESET
  LOGO_UPDATE
  STORAGE
  FEATURE_REQUEST
  CARD_DESIGN
  SUBSCRIPTION
  OTHER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ExamType {
  MONTHLY
  MID_TERM
  FINAL
  BOARD
  SUPPLY
}

enum PersonDocType {
  STUDENT
  TEACHER
}

enum DocumentCategory {
  CNIC
  B_FORM
  DEGREE
  CERTIFICATE
  TRANSCRIPT
  APPOINTMENT_LETTER
  EXPERIENCE_LETTER
  PHOTO_ID
  OTHER
}

// ─── Platform Tables (no instituteId) ────────────────────────────────────────

model SubscriptionPlan {
  id             String       @id @default(uuid())
  name           String       @db.VarChar(100)
  billingCycle   BillingCycle
  price          Decimal      @db.Decimal(10, 2)
  storageQuotaMB Int          @default(5120)
  maxUsers       Int          @default(500)
  allowedModules String[]
  isCustom       Boolean      @default(false)
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())

  institutes Institute[]
  invoices   SubscriptionInvoice[]
}

// ─── Tenant Root ─────────────────────────────────────────────────────────────

model Institute {
  id              String          @id @default(uuid())
  instituteCode   String          @unique @db.VarChar(20)
  name            String          @db.VarChar(200)
  logo            String?         @db.VarChar(500)
  address         String?
  phone           String?         @db.VarChar(20)
  email           String?         @db.VarChar(200)
  status          InstituteStatus @default(ACTIVE)
  planId          String?
  plan            SubscriptionPlan? @relation(fields: [planId], references: [id])
  storageQuotaMB  Int             @default(5120)
  storageUsedMB   Int             @default(0)
  activeModules   String[]
  settings        Json          @default("{}")
  expiryDate      DateTime?
  deletedAt       DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  users              User[]
  students           Student[]
  teachers           Teacher[]
  departments        Department[]
  courses            Course[]
  subjects           Subject[]
  batches            Batch[]
  sections           Section[]
  sessions           Session[]
  semesters          Semester[]
  attendance         Attendance[]
  feeStructures      FeeStructure[]
  fees               Fee[]
  exams              Exam[]
  results            Result[]
  timetable          Timetable[]
  assignments        Assignment[]
  libraryBooks       LibraryBook[]
  libraryIssues      LibraryIssue[]
  hostelRooms        HostelRoom[]
  hostelAllotments   HostelAllotment[]
  transportRoutes    TransportRoute[]
  transportAllotments TransportAllotment[]
  notifications      Notification[]
  announcements      Announcement[]
  cardDesigns        CardDesign[]
  certificates       Certificate[]
  loginHistory       LoginHistory[]
  salaries           Salary[]
  leaveRequests      LeaveRequest[]
  inventoryItems     InventoryItem[]
  supportTickets     SupportTicket[]
  auditLogs          AuditLog[]
  subscriptionInvoices SubscriptionInvoice[]
  individualCourses    IndividualCourse[]
  teacherAssignments TeacherAssignment[]
  personDocuments    PersonDocument[]
  feeRequests        FeeRequest[]
  // Enterprise relations
  guardians          Guardian[]
  parentStudentLinks ParentStudentLink[]
  buildings          Building[]
  classrooms         Classroom[]
  rooms              Room[]
  calendarEvents     AcademicCalendarEvent[]
  hostelBlocks       HostelBlock[]
  hostelFloors       HostelFloor[]
  hostelRoomsExt     HostelRoomExtended[]
  buses              Bus[]
  transportStops     TransportStop[]
  routeStops         RouteStop[]
  routeBuses         RouteBus[]
  questionBanks      QuestionBank[]
  quizzes            Quiz[]
  quizAnswers        QuizAnswer[]
  assignmentFiles    AssignmentFile[]
  vendors            Vendor[]
  purchaseOrders     PurchaseOrder[]
  inventoryTxns      InventoryTransaction[]
  assets             Asset[]
  maintenanceRecords MaintenanceRecord[]
  salaryComponents   SalaryComponent[]
  payrollDetails     PayrollDetail[]
  leaveBalances      LeaveBalance[]
  biometricLogs      BiometricLog[]
  emailLogs          EmailLog[]
  smsLogs            SmsLog[]
  fileStorageRecords FileStorageRecord[]
  featureFlagOverrides InstituteFeatureFlag[]
  theme              InstituteTheme?
  branding           InstituteBranding?
  backups            BackupRecord[]
  webhooks           Webhook[]
  activityStreams    ActivityStream[]
  apiKeys            ApiKey[]
  workflowDefinitions WorkflowDefinition[]
  workflowInstances  WorkflowInstance[]
  formDefinitions    FormDefinition[]
  formSubmissions    FormSubmission[]
  abTestExperiments  AbTestExperiment[]
  documentVersions   DocumentVersion[]
  domainEvents       DomainEvent[]
  ipWhitelists       IpWhitelist[]
  dataConsents       DataConsent[]
  dataExportRequests DataExportRequest[]
  erasureRequests    ErasureRequest[]
  analyticsSnapshots AnalyticsSnapshot[]
}

model User {
  id             String    @id @default(uuid())
  instituteId    String?
  institute      Institute? @relation(fields: [instituteId], references: [id])
  email          String    @unique @db.VarChar(200)
  passwordHash   String    @db.VarChar(500)
  /** Institute-visible portal password (set on create/reset by admin only) */
  portalPassword String?   @db.VarChar(200)
  firstName      String?   @db.VarChar(100)
  lastName       String?   @db.VarChar(100)
  role           UserRole
  isActive       Boolean   @default(true)
  mustChangePass Boolean   @default(false)
  lastLoginAt    DateTime?
  lastLoginIp    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  student        Student?
  teacher        Teacher?
  loginHistory   LoginHistory[]
  ticketsCreated SupportTicket[] @relation("TicketCreator")
  ticketReplies  TicketReply[]
  auditLogs      AuditLog[]
  attendanceMarked Attendance[] @relation("MarkedBy")
  feesCollected  Fee[]         @relation("CollectedBy")
  feeRequestsReviewed FeeRequest[] @relation("FeeRequestReviewer")
  invoicesCreated SubscriptionInvoice[] @relation("InvoiceCreator")
  leaveRequests  LeaveRequest[]
  assignments    Assignment[]
  documentsUploaded PersonDocument[] @relation("UploadedBy")
  guardianProfile Guardian?
  notificationReads NotificationRead[]
  inventoryTxns InventoryTransaction[] @relation("InventoryTxnBy")
  leaveBalances LeaveBalance[]
  biometricLogs BiometricLog[]
  activityStreams ActivityStream[] @relation("ActivityActor")
  apiKeysCreated ApiKey[] @relation("ApiKeyCreator")
  workflowInstancesInitiated WorkflowInstance[] @relation("WorkflowInitiator")
  workflowApprovals WorkflowApproval[] @relation("WorkflowApprover")
  workflowAuditLogs WorkflowAuditLog[] @relation("WorkflowAuditActor")
  formSubmissions FormSubmission[] @relation("FormSubmitter")
  documentVersions DocumentVersion[] @relation("DocVersionCreator")
  userSessions UserSession[]
  mfaDevices MfaDevice[]
  passwordHistories PasswordHistory[]
  dataConsents DataConsent[]
  dataExportRequests DataExportRequest[] @relation("ExportRequester")

  @@index([instituteId, role])
  @@index([email])
}

// ─── Academic Structure ──────────────────────────────────────────────────────

model Department {
  id          String    @id @default(uuid())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  name        String    @db.VarChar(200)
  code        String?   @db.VarChar(20)
  createdAt   DateTime  @default(now())

  courses Course[]
  teachers Teacher[]

  @@index([instituteId])
}

model Course {
  id           String     @id @default(uuid())
  instituteId  String
  institute    Institute  @relation(fields: [instituteId], references: [id])
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])
  name         String     @db.VarChar(200)
  code         String?    @db.VarChar(20)
  creditHours  Int        @default(0)
  createdAt    DateTime   @default(now())

  subjects Subject[]

  @@index([instituteId])
}

model Subject {
  id          String    @id @default(uuid())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  courseId    String
  course      Course    @relation(fields: [courseId], references: [id])
  name        String    @db.VarChar(200)
  code        String?   @db.VarChar(20)
  creditHours Int       @default(0)
  createdAt   DateTime  @default(now())

  attendance Attendance[]
  results    Result[]
  timetable  Timetable[]
  assignments Assignment[]
  teacherAssignments TeacherAssignment[]

  questionBanks QuestionBank[]

  @@index([instituteId])
}

model Session {
  id          String    @id @default(uuid())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  name        String    @db.VarChar(100)
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean   @default(false)
  createdAt   DateTime  @default(now())

  semesters Semester[]
  batches   Batch[]
  calendarEvents AcademicCalendarEvent[]

  @@index([instituteId])
}

model Semester {
  id          String    @id @default(uuid())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  sessionId   String
  session     Session   @relation(fields: [sessionId], references: [id])
  name        String    @db.VarChar(100)
  number      Int
  startDate   DateTime
  endDate     DateTime
  createdAt   DateTime  @default(now())

  exams Exam[]

  @@index([instituteId])
}

model Batch {
  id          String    @id @default(uuid())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  sessionId   String?
  session     Session?  @relation(fields: [sessionId], references: [id])
  name        String    @db.VarChar(100)
  year        Int?
  createdAt   DateTime  @default(now())

  sections Section[]
  students Student[]

  @@index([instituteId])
}

model Section {
  id          String    @id @default(uuid())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  batchId     String
  batch       Batch     @relation(fields: [batchId], references: [id])
  name        String    @db.VarChar(50)
  capacity    Int?
  createdAt   DateTime  @default(now())

  students Student[]
  teacherAssignments TeacherAssignment[]
  exams    Exam[]
  timetable Timetable[]

  @@index([instituteId])
}

// ─── People ──────────────────────────────────────────────────────────────────

model Student {
  id               String        @id @default(uuid())
  instituteId      String
  institute        Institute     @relation(fields: [instituteId], references: [id])
  userId           String?       @unique
  user             User?         @relation(fields: [userId], references: [id])
  rollNumber       String?       @db.VarChar(50)
  firstName        String        @db.VarChar(100)
  lastName         String        @db.VarChar(100)
  dateOfBirth      DateTime?     @db.Date
  gender           Gender?
  cnic             String?       @db.VarChar(15)
  phone            String?       @db.VarChar(20)
  address          String?
  photo            String?       @db.VarChar(500)
  guardianName     String?       @db.VarChar(200)
  guardianPhone    String?       @db.VarChar(20)
  guardianRelation String?       @db.VarChar(50)
  guardianEmail    String?       @db.VarChar(200)
  fatherName       String?       @db.VarChar(200)
  motherName       String?       @db.VarChar(200)
  registrationNumber String?     @db.VarChar(50)
  admissionNumber  String?       @db.VarChar(50)
  bloodGroup       String?       @db.VarChar(10)
  notes            String?
  enrollmentDate   DateTime?     @db.Date
  status           StudentStatus @default(ACTIVE)
  deletedAt        DateTime?
  archivedAt       DateTime?
  currentBatchId   String?
  currentBatch     Batch?        @relation(fields: [currentBatchId], references: [id])
  currentSectionId String?
  currentSection   Section?      @relation(fields: [currentSectionId], references: [id])
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  attendance          Attendance[]
  fees                Fee[]
  results             Result[]
  submissions         Submission[]
  libraryIssues       LibraryIssue[]
  hostelAllotments    HostelAllotment[]
  transportAllotments TransportAllotment[]
  certificates        Certificate[]
  documents           PersonDocument[]
  feeRequests         FeeRequest[]
  parentLinks         ParentStudentLink[]
  quizAnswers         QuizAnswer[]
  biometricLogs       BiometricLog[]
  dataConsents        DataConsent[]
  promotions          StudentPromotion[]
  studentNotes        StudentNote[]
  courseEnrollments   IndividualCourseEnrollment[]

  @@unique([instituteId, rollNumber])
  @@index([instituteId, deletedAt])
}

model Teacher {
  id             String        @id @default(uuid())
  instituteId    String
  institute      Institute     @relation(fields: [instituteId], references: [id])
  userId         String?       @unique
  user           User?         @relation(fields: [userId], references: [id])
  employeeCode   String?       @db.VarChar(50)
  firstName      String        @db.VarChar(100)
  lastName       String        @db.VarChar(100)
  qualification  String?       @db.VarChar(200)
  specialization String?       @db.VarChar(200)
  departmentId   String?
  department     Department?   @relation(fields: [departmentId], references: [id])
  designation    String?       @db.VarChar(100)
  employmentType String?       @db.VarChar(50)
  experienceYears Int?
  phone          String?       @db.VarChar(20)
  photo          String?       @db.VarChar(500)
  paymentMethod  String?       @db.VarChar(50)
  allowances     Decimal?      @db.Decimal(10, 2)
  deductions     Decimal?      @db.Decimal(10, 2)
  notes          String?
  joiningDate    DateTime?     @db.Date
  salary         Decimal?      @db.Decimal(10, 2)
  status         TeacherStatus @default(ACTIVE)
  deletedAt      DateTime?
  archivedAt     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  timetable     Timetable[]
  salaries      Salary[]
  leaveRequests LeaveRequest[]
  assignments   TeacherAssignment[]
  documents     PersonDocument[]
  individualCourses IndividualCourseTeacher[]

  @@index([instituteId])
}

model StudentPromotion {
  id            String   @id @default(uuid())
  instituteId   String
  studentId     String
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  fromBatchId   String?
  toBatchId     String?
  fromSectionId String?
  toSectionId   String?
  sessionName   String?  @db.VarChar(100)
  promotedAt    DateTime @default(now())
  notes         String?

  @@index([studentId])
}

model StudentNote {
  id          String   @id @default(uuid())
  instituteId String
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  authorId    String?
  content     String
  createdAt   DateTime @default(now())

  @@index([studentId])
}

enum IndividualCourseStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
}

enum CourseEnrollmentStatus {
  ENROLLED
  COMPLETED
  DROPPED
  SUSPENDED
}

model IndividualCourse {
  id                String                 @id @default(uuid())
  instituteId       String
  institute         Institute              @relation(fields: [instituteId], references: [id])
  name              String                 @db.VarChar(200)
  code              String                 @db.VarChar(50)
  duration          String?                @db.VarChar(100)
  startDate         DateTime?
  endDate           DateTime?
  capacity          Int                    @default(30)
  description       String?
  status            IndividualCourseStatus @default(ACTIVE)
  admissionFee      Decimal                @default(0) @db.Decimal(10, 2)
  monthlyFee        Decimal                @default(0) @db.Decimal(10, 2)
  oneTimeFee        Decimal                @default(0) @db.Decimal(10, 2)
  discountAmount    Decimal                @default(0) @db.Decimal(10, 2)
  scholarshipAmount Decimal                @default(0) @db.Decimal(10, 2)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  teachers    IndividualCourseTeacher[]
  enrollments IndividualCourseEnrollment[]

  @@unique([instituteId, code])
  @@index([instituteId, status])
}

model IndividualCourseTeacher {
  id        String           @id @default(uuid())
  courseId  String
  course    IndividualCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacherId String
  teacher   Teacher          @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())

  @@unique([courseId, teacherId])
}

model IndividualCourseEnrollment {
  id          String                 @id @default(uuid())
  instituteId String
  courseId    String
  course      IndividualCourse       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  studentId   String
  student     Student                @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status      CourseEnrollmentStatus @default(ENROLLED)
  enrolledAt  DateTime               @default(now())
  feePaid     Decimal                @default(0) @db.Decimal(10, 2)
  feeDue      Decimal                @default(0) @db.Decimal(10, 2)
  notes       String?

  @@unique([courseId, studentId])
  @@index([instituteId])
}

model PersonDocument {
  id           String           @id @default(uuid())
  instituteId  String
  institute    Institute        @relation(fields: [instituteId], references: [id])
  personType   PersonDocType
  studentId    String?
  student      Student?         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacherId    String?
  teacher      Teacher?         @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  category     DocumentCategory @default(OTHER)
  title        String           @db.VarChar(200)
  fileName     String           @db.VarChar(300)
  mimeType     String?          @db.VarChar(100)
  fileSize     Int?
  cloudinaryId String           @db.VarChar(300)
  url          String           @db.VarChar(500)
  uploadedById String?
  uploadedBy   User?            @relation("UploadedBy", fields: [uploadedById], references: [id])
  createdAt    DateTime         @default(now())

  @@index([instituteId, studentId])
  @@index([instituteId, teacherId])
}

model TeacherAssignment {
  id          String    @id @default(uuid())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  teacherId   String
  teacher     Teacher   @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subjectId   String
  subject     Subject   @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  sectionId   String
  section     Section   @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([instituteId, teacherId, subjectId, sectionId])
  @@index([instituteId, teacherId])
  @@index([instituteId, sectionId])
}

// ─── Academic Operations ─────────────────────────────────────────────────────

model Attendance {
  id            String           @id @default(uuid())
  instituteId   String
  institute     Institute        @relation(fields: [instituteId], references: [id])
  studentId     String
  student       Student          @relation(fields: [studentId], references: [id])
  subjectId     String
  subject       Subject          @relation(fields: [subjectId], references: [id])
  date          DateTime         @db.Date
  lectureNumber Int              @default(1)
  status        AttendanceStatus
  markedById    String?
  markedBy      User?            @relation("MarkedBy", fields: [markedById], references: [id])
  createdAt     DateTime         @default(now())

  @@unique([instituteId, studentId, subjectId, date, lectureNumber])
  @@index([instituteId, studentId, date])
}

model Exam {
  id             String    @id @default(uuid())
  instituteId    String
  institute      Institute @relation(fields: [instituteId], references: [id])
  name           String    @db.VarChar(200)
  examType       ExamType  @default(FINAL)
  sectionId      String?
  section        Section?  @relation(fields: [sectionId], references: [id])
  semesterId     String?
  semester       Semester? @relation(fields: [semesterId], references: [id])
  startDate      DateTime?
  endDate        DateTime?
  theoryMax      Decimal   @default(75) @db.Decimal(5, 2)
  practicalMax   Decimal   @default(15) @db.Decimal(5, 2)
  internalMax    Decimal   @default(10) @db.Decimal(5, 2)
  passPercentage Decimal   @default(33) @db.Decimal(5, 2)
  isPublished    Boolean   @default(false)
  createdAt      DateTime  @default(now())

  results Result[]

  @@index([instituteId])
}

model Result {
  id             String    @id @default(uuid())
  instituteId    String
  institute      Institute @relation(fields: [instituteId], references: [id])
  studentId      String
  student        Student   @relation(fields: [studentId], references: [id])
  subjectId      String
  subject        Subject   @relation(fields: [subjectId], references: [id])
  examId         String
  exam           Exam      @relation(fields: [examId], references: [id])
  theoryMarks    Decimal?  @db.Decimal(5, 2)
  practicalMarks Decimal?  @db.Decimal(5, 2)
  internalMarks  Decimal?  @db.Decimal(5, 2)
  totalMarks     Decimal?  @db.Decimal(5, 2)
  maxMarks       Decimal?  @db.Decimal(5, 2)
  grade          String?   @db.VarChar(5)
  gradePoints    Decimal?  @db.Decimal(3, 2)
  isPassed       Boolean?
  remarks        String?
  position       Int?
  publishedAt    DateTime?
  createdAt      DateTime  @default(now())

  @@unique([instituteId, studentId, subjectId, examId])
  @@index([instituteId])
}

model Timetable {
  id          String    @id @default(uuid())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  subjectId   String
  subject     Subject   @relation(fields: [subjectId], references: [id])
  sectionId   String?
  section     Section?  @relation(fields: [sectionId], references: [id])
  teacherId   String?
  teacher     Teacher?  @relation(fields: [teacherId], references: [id])
  dayOfWeek   Int
  startTime   String    @db.VarChar(10)
  endTime     String    @db.VarChar(10)
  room        String?   @db.VarChar(50)
  createdAt   DateTime  @default(now())

  @@index([instituteId])
}

model Assignment {
  id          String    @id @default(uuid())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  subjectId   String
  subject     Subject   @relation(fields: [subjectId], references: [id])
  teacherId   String
  teacher     User      @relation(fields: [teacherId], references: [id])
  title       String    @db.VarChar(300)
  description String?
  dueDate     DateTime?
  maxMarks    Decimal?  @db.Decimal(5, 2)
  createdAt   DateTime  @default(now())

  submissions Submission[]
  files       AssignmentFile[]

  @@index([instituteId])
}

model Submission {
  id           String     @id @default(uuid())
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id])
  studentId    String
  student      Student    @relation(fields: [studentId], references: [id])
  content      String?
  attachment   String?    @db.VarChar(500)
  marks        Decimal?   @db.Decimal(5, 2)
  submittedAt  DateTime   @default(now())

  @@unique([assignmentId, studentId])
}

// ─── Finance ─────────────────────────────────────────────────────────────────

model FeeStructure {
  id          String    @id @default(uuid())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  name        String    @db.VarChar(200)
  amount      Decimal   @db.Decimal(10, 2)
  frequency   String?   @db.VarChar(50)
  createdAt   DateTime  @default(now())

  fees Fee[]

  @@index([instituteId])
}

model Fee {
  id             String       @id @default(uuid())
  instituteId    String
  institute      Institute    @relation(fields: [instituteId], references: [id])
  studentId      String
  student        Student      @relation(fields: [studentId], references: [id])
  feeStructureId String
  feeStructure   FeeStructure @relation(fields: [feeStructureId], references: [id])
  amount         Decimal      @db.Decimal(10, 2)
  fine           Decimal      @default(0) @db.Decimal(10, 2)
  discount       Decimal      @default(0) @db.Decimal(10, 2)
  dueDate        DateTime?    @db.Date
  paidDate       DateTime?    @db.Date
  status         FeeStatus    @default(PENDING)
  receiptNumber  String?      @db.VarChar(50)
  collectedById  String?
  collectedBy    User?        @relation("CollectedBy", fields: [collectedById], references: [id])
  assignmentScope FeeAssignmentScope @default(INDIVIDUAL)
  parentFeeId    String?
  parentFee      Fee?         @relation("FeeInstallments", fields: [parentFeeId], references: [id])
  installments   Fee[]        @relation("FeeInstallments")
  installmentNo  Int?
  notes          String?
  createdAt      DateTime     @default(now())

  feeRequests    FeeRequest[]

  @@index([instituteId, studentId])
  @@index([instituteId, status])
  @@index([parentFeeId])
}

model FeeRequest {
  id               String           @id @default(uuid())
  instituteId      String
  institute        Institute        @relation(fields: [instituteId], references: [id])
  studentId        String
  student          Student          @relation(fields: [studentId], references: [id])
  feeId            String?
  fee              Fee?             @relation(fields: [feeId], references: [id])
  requestType      FeeRequestType
  reason           String
  status           FeeRequestStatus @default(PENDING)
  adminNotes       String?
  reviewedById     String?
  reviewedBy       User?            @relation("FeeRequestReviewer", fields: [reviewedById], references: [id])
  reviewedAt       DateTime?
  installmentCount Int?
  extensionDays    Int?
  approvedAmount   Decimal?         @db.Decimal(10, 2)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([instituteId, status])
  @@index([studentId])
}

model SubscriptionInvoice {
  id            String           @id @default(uuid())
  invoiceNumber String           @unique @db.VarChar(50)
  instituteId   String
  institute     Institute        @relation(fields: [instituteId], references: [id])
  planId        String
  plan          SubscriptionPlan @relation(fields: [planId], references: [id])
  type          InvoiceType
  amount        Decimal          @db.Decimal(10, 2)
  status        InvoiceStatus    @default(PENDING)
  issuedAt      DateTime         @default(now())
  dueDate       DateTime?
  graceEndsAt   DateTime?
  paidAt        DateTime?
  paymentRef    String?          @db.VarChar(200)
  paymentProof  String?          @db.VarChar(500)
  periodFrom    DateTime?
  periodTo      DateTime?
  notes         String?
  createdById   String?
  createdBy     User?            @relation("InvoiceCreator", fields: [createdById], references: [id])
  createdAt     DateTime         @default(now())

  @@index([instituteId])
}

// ─── Support & Audit ─────────────────────────────────────────────────────────

model SupportTicket {
  id          String         @id @default(uuid())
  instituteId String
  institute   Institute      @relation(fields: [instituteId], references: [id])
  createdById String
  createdBy   User           @relation("TicketCreator", fields: [createdById], references: [id])
  subject     String         @db.VarChar(300)
  category    TicketCategory
  description String
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(MEDIUM)
  closedAt    DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  replies TicketReply[]

  @@index([instituteId])
  @@index([status])
}

model TicketReply {
  id          String        @id @default(uuid())
  ticketId    String
  ticket      SupportTicket @relation(fields: [ticketId], references: [id])
  repliedById String
  repliedBy   User          @relation(fields: [repliedById], references: [id])
  message     String
  attachments String[]
  createdAt   DateTime      @default(now())
}

model AuditLog {
  id          String     @id @default(uuid())
  instituteId String?
  institute   Institute? @relation(fields: [instituteId], references: [id])
  userId      String?
  user        User?      @relation(fields: [userId], references: [id])
  action      String     @db.VarChar(100)
  entity      String     @db.VarChar(50)
  entityId    String?
  oldValue    Json?
  newValue    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime   @default(now())

  @@index([instituteId, createdAt])
  @@index([userId, createdAt])
}

model LoginHistory {
  id          String     @id @default(uuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id])
  instituteId String?
  institute   Institute? @relation(fields: [instituteId], references: [id])
  ipAddress   String?
  userAgent   String?
  success     Boolean    @default(true)
  createdAt   DateTime   @default(now())

  @@index([userId, createdAt])
  @@index([instituteId, createdAt])
}

