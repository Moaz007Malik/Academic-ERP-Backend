{
  "name": "academic-erp-backend",
  "version": "1.0.0",
  "description": "Multi-Tenant Academic ERP API",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "dev": "node --watch server.js",
    "postinstall": "prisma generate",
